Options -MultiViews -Indexes
DirectoryIndex index.html
RewriteEngine On
RewriteBase /

# ── Charset ──────────────────────────────────────────────────
AddDefaultCharset UTF-8
AddCharset UTF-8 .html .css .js

# ── Compression ──────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ── Caching ──────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                "access plus 0 seconds"
  ExpiresByType text/css                 "access plus 1 year"
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType font/woff2               "access plus 1 year"
  ExpiresByType font/woff                "access plus 1 year"
  ExpiresByType image/jpeg               "access plus 1 day"
  ExpiresByType image/png                "access plus 1 day"
  ExpiresByType image/webp               "access plus 1 day"
  ExpiresByType image/avif               "access plus 1 day"
  ExpiresByType image/svg+xml            "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  # Next.js hashed chunks — safe to cache forever
  <LocationMatch "^/_next/static/">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </LocationMatch>
  # HTML — always revalidate
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Rewrites ─────────────────────────────────────────────────

# 1. Serve existing files directly (JS, CSS, images, fonts…)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. Root: detect browser language and redirect
RewriteCond %{HTTP:Accept-Language} ^ar [NC]
RewriteRule ^$ /ar/ [R=302,L]
RewriteRule ^$ /en/ [R=302,L]

# 3. Add trailing slash when the path maps to a directory
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*[^/])$ /$1/ [R=301,L]

# 4. Serve index.html for clean directory URLs
RewriteCond %{REQUEST_URI} !\.
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}index.html -f
RewriteRule ^ %{REQUEST_URI}index.html [L]

# ── Errors ───────────────────────────────────────────────────
ErrorDocument 404 /404.html
